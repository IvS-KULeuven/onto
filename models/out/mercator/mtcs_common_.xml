              </documentation>
            </variable>
          </inputVars>
          <outputVars>
            <variable name="forward">
              <type><BOOL /></type>
              <addData>
                <data name="http://www.3s-software.com/plcopenxml/attributes" handleUnknown="implementation">
                  <Attributes>
                    <Attribute Name="OPC.UA.DA" Value="1" />
                    <Attribute Name="OPC.UA.DA.Access" Value="1" />
                  </Attributes>
                </data>
              </addData>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">Moving forwared</xhtml>
              </documentation>
            </variable>
            <variable name="backward">
              <type><BOOL /></type>
              <addData>
                <data name="http://www.3s-software.com/plcopenxml/attributes" handleUnknown="implementation">
                  <Attributes>
                    <Attribute Name="OPC.UA.DA" Value="1" />
                    <Attribute Name="OPC.UA.DA.Access" Value="1" />
                  </Attributes>
                </data>
              </addData>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">Moving backward</xhtml>
              </documentation>
            </variable>
            <variable name="standstill">
              <type><BOOL /></type>
              <addData>
                <data name="http://www.3s-software.com/plcopenxml/attributes" handleUnknown="implementation">
                  <Attributes>
                    <Attribute Name="OPC.UA.DA" Value="1" />
                    <Attribute Name="OPC.UA.DA.Access" Value="1" />
                  </Attributes>
                </data>
              </addData>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">Standing still</xhtml>
              </documentation>
            </variable>
          </outputVars>
          <inOutVars>
          </inOutVars>
          <localVars>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">forward := (actVel > (ABS(tolerance))) AND superState;
backward := (actVel < (-(ABS(tolerance)))) AND superState;
standstill := (NOT(forward OR backward)) AND superState;
</xhtml>
          </ST>
        </body>
