      <pou name="ApertureStatus" pouType="functionBlock">
        <interface>
          <inputVars>
            <variable name="superState">
              <type><BOOL /></type>
              <initialValue><simpleValue value="TRUE" /></initialValue>
              <addData>
                <data name="http://www.3s-software.com/plcopenxml/attributes" handleUnknown="implementation">
                  <Attributes>
                  </Attributes>
                </data>
              </addData>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">Super state (TRUE if the super state is active, or if there is no super state)</xhtml>
              </documentation>
            </variable>
            <variable name="isOpen">
              <type><BOOL /></type>
              <addData>
                <data name="http://www.3s-software.com/plcopenxml/attributes" handleUnknown="implementation">
                  <Attributes>
                  </Attributes>
                </data>
              </addData>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">TRUE if the &#39;open&#39; limit switch is active</xhtml>
              </documentation>
            </variable>
            <variable name="isClosed">
              <type><BOOL /></type>
              <addData>
                <data name="http://www.3s-software.com/plcopenxml/attributes" handleUnknown="implementation">
                  <Attributes>
                  </Attributes>
                </data>
              </addData>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">TRUE if the &#39;open&#39; limit switch is active</xhtml>
              </documentation>
            </variable>
          </inputVars>
          <outputVars>
            <variable name="open">
              <type><BOOL /></type>
              <addData>
                <data name="http://www.3s-software.com/plcopenxml/attributes" handleUnknown="implementation">
                  <Attributes>
                    <Attribute Name="OPC.UA.DA" Value="1" />
                    <Attribute Name="OPC.UA.DA.Access" Value="1" />
                  </Attributes>
                </data>
              </addData>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">The aperture is open</xhtml>
              </documentation>
            </variable>
            <variable name="closed">
              <type><BOOL /></type>
              <addData>
                <data name="http://www.3s-software.com/plcopenxml/attributes" handleUnknown="implementation">
                  <Attributes>
                    <Attribute Name="OPC.UA.DA" Value="1" />
                    <Attribute Name="OPC.UA.DA.Access" Value="1" />
                  </Attributes>
                </data>
              </addData>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">The aperture is closed</xhtml>
              </documentation>
            </variable>
            <variable name="partiallyOpen">
              <type><BOOL /></type>
              <addData>
                <data name="http://www.3s-software.com/plcopenxml/attributes" handleUnknown="implementation">
                  <Attributes>
                    <Attribute Name="OPC.UA.DA" Value="1" />
                    <Attribute Name="OPC.UA.DA.Access" Value="1" />
                  </Attributes>
                </data>
              </addData>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">The aperture is partially open</xhtml>
              </documentation>
            </variable>
            <variable name="undefined">
              <type><BOOL /></type>
              <addData>
                <data name="http://www.3s-software.com/plcopenxml/attributes" handleUnknown="implementation">
                  <Attributes>
                    <Attribute Name="OPC.UA.DA" Value="1" />
                    <Attribute Name="OPC.UA.DA.Access" Value="1" />
                  </Attributes>
                </data>
              </addData>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">The aperture status is undefined</xhtml>
              </documentation>
            </variable>
          </outputVars>
          <inOutVars>
          </inOutVars>
          <localVars>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">open := (isOpen AND (NOT(isClosed))) AND superState;
closed := (isClosed AND (NOT(isOpen))) AND superState;
partiallyOpen := (NOT(isOpen OR isClosed)) AND superState;
undefined := (isOpen AND isClosed) AND superState;
</xhtml>
          </ST>
        </body>
        <addData>
        </addData>
      </pou>
